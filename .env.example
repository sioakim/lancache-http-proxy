# Copy to .env and edit.

# ─────────────────────────────────────────────────────────────────────────────
# YOUR UPSTREAM FORWARD PROXY — the whole point of this project.
# Game-download cache MISSes are sent through this proxy. Set it to your ISP's
# HTTP proxy (or any forward proxy reachable from this host).
# ─────────────────────────────────────────────────────────────────────────────
# HOST only — a bare hostname or IP, with NO scheme and NO port (no colon).
# NOTE: this name is resolved by the relay container's own resolver (Docker's
# embedded resolver), NOT by lancache-dns / UPSTREAM_DNS. If your proxy's name
# only resolves on your ISP's internal DNS, put its IP address here instead.
UPSTREAM_PROXY_HOST=proxy.example-isp.net
UPSTREAM_PROXY_PORT=8080

# Optional: set ONLY if your forward proxy requires authentication. Leave blank
# otherwise. HTTP Basic only — NTLM/Kerberos proxies are not supported.
UPSTREAM_PROXY_USER=
UPSTREAM_PROXY_PASS=

# The IP address your clients will use as their DNS server (and that game CDN
# domains resolve to). Usually the LAN IP of this Docker host, or a dedicated
# macvlan IP. Clients only use the cache when their DNS points here.
LANCACHE_IP=192.168.1.10

# Where the cache + logs live on the host (a fast disk with lots of space).
# Best kept OUTSIDE the repo (an absolute path). If you point it at an in-repo
# path other than ./data, add that path to .gitignore so the cache isn't tracked.
CACHE_ROOT=./data

# Max cache size. Leave headroom below the filesystem size.
CACHE_DISK_SIZE=1000g

# How long cached objects are kept.
CACHE_MAX_AGE=3650d

# Upstream DNS for non-game (passthrough) lookups. Your ISP/public resolver.
UPSTREAM_DNS=1.1.1.1 8.8.8.8

# ── Optional: self-healing watchdog (the 'watchdog' service) ──
# Alerts — leave all blank to run log-only (it still self-heals).
# Pushover (phone push) — token from an app you create at pushover.net:
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
# Or a webhook (Discord-style, receives {"content":"..."}; adapt notify() for Slack):
WATCHDOG_WEBHOOK_URL=
# Resolver the watchdog uses to send alerts — kept off the cache so it can still
# notify you when the cache itself (your normal DNS) is what's down.
WATCHDOG_DNS=1.1.1.1
