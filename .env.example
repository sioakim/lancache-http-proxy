# Copy to .env and edit.

# The IP address your clients will use as their DNS server (and that game CDN
# domains resolve to). Usually the LAN IP of this Docker host, or a dedicated
# macvlan IP. Clients only use the cache when their DNS points here.
LANCACHE_IP=192.168.1.10

# Where the cache + logs live on the host (a fast disk with lots of space).
CACHE_ROOT=./data

# Max cache size. Leave headroom below the filesystem size.
CACHE_DISK_SIZE=1000g

# How long cached objects are kept.
CACHE_MAX_AGE=3650d

# Upstream DNS for non-game (passthrough) lookups. Your ISP/public resolver.
UPSTREAM_DNS=1.1.1.1 8.8.8.8

# NOTE: the upstream forward proxy itself is set in conf/squid.conf
# (the `cache_peer` line), not here.
